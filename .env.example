# Copy to .env and fill in. .env is gitignored.

# --- Database ----------------------------------------------------------------
POSTGRES_USER=tracker
POSTGRES_DB=tracker
# Required. Generate one: openssl rand -base64 32
POSTGRES_PASSWORD=

# Used by scripts/migrate.mjs and `npm run dev` when running outside compose.
# Inside compose the app builds this itself from the POSTGRES_* values above.
DATABASE_URL=postgres://tracker:CHANGEME@localhost:5432/tracker

# --- Photo import ------------------------------------------------------------
# One of: google-vision | claude | gemini | tesseract
#
# tesseract runs in the browser and needs no credential — it's the only one that
# works offline, and the fallback when nothing else is set up. The rest need the
# matching key below. A missing credential degrades to manual entry rather than
# breaking anything, so leaving all of this blank is a valid configuration.
OCR_PROVIDER=google-vision

# google-vision: an API key, not a service account. Create one in the Google
# Cloud console and restrict it to the Cloud Vision API. Free tier covers about
# 1000 images/month, well above expected use.
GOOGLE_VISION_API_KEY=

# claude: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=
